{
    "name": "resume-v2",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "lint": "eslint .",
        "typecheck": "astro check",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:ui": "playwright test --ui",
        "capture:skyline": "node scripts/capture-skyline.mjs",
        "audit:lighthouse": "lighthouse http://127.0.0.1:4321 --chrome-flags=\"--headless\"",
        "format": "prettier --ignore-path .gitignore --write \"**/*.+(css|scss|js|mjs|ts|astro|json)\""
    },
    "dependencies": {
        "astro": "^5.2.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@playwright/test": "^1.61.1",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "^26.1.1",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^8.57.1",
        "eslint-plugin-astro": "^1.7.0",
        "lighthouse": "^13.4.0",
        "prettier": "^3.5.1",
        "prettier-plugin-astro": "^0.14.1",
        "prettier-plugin-css-order": "^2.1.2",
        "sass": "^1.101.0",
        "typescript": "~5.7.2"
    }
}
