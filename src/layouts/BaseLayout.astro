---
import Header from '../components/Header/Header.astro';
import { jobs } from '../data/experience';
import { PAGE_SURFACE_BY_HASH, PAGE_THEME_COLORS } from '../scripts/page-theme';
import {
    getSkylineStateBootstrapScript,
    SKYLINE_THEME_COLORS,
} from '../scripts/skyline/time-state';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Albert Yang | Software Engineer',
    description = 'Albert Yang is a Toronto-based Software Engineer II at Super.com with 6+ years of experience, open to remote roles and US relocation with visa sponsorship.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const socialImageURL = new URL(
    '/images/albert-yang-social-card.png',
    Astro.site,
).toString();
const socialImageAlt =
    'Albert Yang, Toronto Software Engineer, alongside an illustrated Toronto skyline at night.';
const currentJob = jobs[0];
const websiteId = `${canonicalURL}#website`;
const profilePageId = `${canonicalURL}#profile-page`;
const personId = `${canonicalURL}#albert-yang`;
const profilePageStructuredData = JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'WebSite',
            '@id': websiteId,
            url: canonicalURL,
            name: 'Albert Yang',
            description,
            publisher: { '@id': personId },
        },
        {
            '@type': 'ProfilePage',
            '@id': profilePageId,
            url: canonicalURL,
            name: title,
            description,
            isPartOf: { '@id': websiteId },
            mainEntity: { '@id': personId },
        },
        {
            '@type': 'Person',
            '@id': personId,
            name: 'Albert Yang',
            url: canonicalURL,
            description,
            jobTitle: currentJob.role,
            worksFor: {
                '@type': 'Organization',
                name: currentJob.company,
            },
            homeLocation: {
                '@type': 'Place',
                name: 'Toronto, Ontario, Canada',
            },
            sameAs: [
                'https://www.linkedin.com/in/albrtyng/',
                'https://github.com/albrtyng',
            ],
        },
    ],
});
const skylineStateBootstrapScript = getSkylineStateBootstrapScript();
const initialSurfaceThemeColors = JSON.stringify(PAGE_THEME_COLORS);
const pageSurfaceByHash = JSON.stringify(PAGE_SURFACE_BY_HASH);
const initialHeaderSurfaceBootstrapScript = `
    try {
        const root = document.documentElement;
        root.dataset.js = 'true';
        const savedHeader = history.state?.portfolioHeader;
        const hashSurface = ${pageSurfaceByHash}[window.location.hash];
        const savedSurface = ['hero', 'paper', 'contact'].includes(
            savedHeader?.surface,
        )
            ? savedHeader.surface
            : null;
        const savedScrollY = Number.isFinite(savedHeader?.scrollY)
            ? Math.max(savedHeader.scrollY, 0)
            : null;
        const surface = hashSurface ?? savedSurface ?? 'hero';
        const collapsed =
            hashSurface
                ? true
                : typeof savedHeader?.collapsed === 'boolean'
                ? savedHeader.collapsed
                : false;

        root.dataset.pageSurface = surface;

        if (hashSurface || savedSurface) {
            root.dataset.initialHeaderSurface = surface;
        }

        if (!hashSurface && savedScrollY) {
            root.dataset.initialHeaderScrollY = String(savedScrollY);
        }

        root.toggleAttribute(
            'data-initial-header-collapsed',
            collapsed,
        );

        const themeColor = document.querySelector('meta[name="theme-color"]');
        const state = root.dataset.timeState ?? 'dusk';
        const colors = ${initialSurfaceThemeColors};
        if (themeColor) {
            themeColor.content =
                surface === 'paper'
                    ? colors.paper
                    : colors[surface][state];
        }
    } catch {
        // The semantic header remains a complete hero-state fallback.
    }
`;
---

<!doctype html>
<html lang="en" data-time-state="dusk" data-page-surface="hero">
    <head>
        <meta charset="UTF-8" />
        <meta name="theme-color" content={SKYLINE_THEME_COLORS.dusk} />
        <script is:inline set:html={skylineStateBootstrapScript} />
        <script is:inline set:html={initialHeaderSurfaceBootstrapScript} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="robots" content="max-image-preview:large" />
        <meta name="color-scheme" content="light dark" />
        <title>{title}</title>
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:locale" content="en_CA" />
        <meta property="og:site_name" content="Albert Yang" />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={socialImageAlt} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImageURL} />
        <meta name="twitter:image:alt" content={socialImageAlt} />

        <script
            is:inline
            type="application/ld+json"
            set:html={profilePageStructuredData}
        />

        <link
            rel="preload"
            href="/fonts/GeneralSans-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/GeneralSans-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    </head>
    <body>
        <a href="#experience" class="skip-link">Skip to experience</a>
        <Header />
        <slot />
    </body>
</html>
