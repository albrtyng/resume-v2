---
import Header from '../components/Header/Header.astro';
import { jobs } from '../data/experience';
import {
    getSkylineStateBootstrapScript,
    SKYLINE_THEME_COLORS,
} from '../scripts/skyline/time-state';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Albert Yang | Toronto Software Engineer',
    description = 'Albert Yang is a Toronto-based Software Engineer with 6+ years of experience building dependable products and systems used around the world.',
} = Astro.props;

const canonicalURL = 'https://albertyang.ca/';
const socialImageURL = `${canonicalURL}images/albert-yang-social-card.png`;
const socialImageAlt =
    'Albert Yang, Toronto Software Engineer, alongside an illustrated Toronto skyline at night.';
const currentJob = jobs[0];
const profilePageStructuredData = JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    '@id': canonicalURL,
    url: canonicalURL,
    name: title,
    description,
    mainEntity: {
        '@type': 'Person',
        '@id': `${canonicalURL}#albert-yang`,
        name: 'Albert Yang',
        url: canonicalURL,
        description,
        jobTitle: currentJob.role,
        worksFor: {
            '@type': 'Organization',
            name: currentJob.company,
        },
        homeLocation: {
            '@type': 'Place',
            name: 'Toronto, Ontario, Canada',
        },
        sameAs: [
            'https://www.linkedin.com/in/albrtyng/',
            'https://github.com/albrtyng',
        ],
    },
});
const skylineStateBootstrapScript = getSkylineStateBootstrapScript();
const initialHeaderSurfaceBootstrapScript = `
    try {
        const savedHeader = history.state?.portfolioHeader;
        const hashSurface = {
            '#experience': 'paper',
            '#capabilities': 'paper',
            '#contact': 'contact',
        }[window.location.hash];
        const savedSurface = ['hero', 'paper', 'contact'].includes(
            savedHeader?.surface,
        )
            ? savedHeader.surface
            : null;
        const savedScrollY = Number.isFinite(savedHeader?.scrollY)
            ? Math.max(savedHeader.scrollY, 0)
            : null;
        const surface = hashSurface ?? savedSurface;
        const collapsed =
            hashSurface
                ? true
                : typeof savedHeader?.collapsed === 'boolean'
                ? savedHeader.collapsed
                : false;

        if (surface) {
            document.documentElement.dataset.initialHeaderSurface = surface;
        }

        if (!hashSurface && savedScrollY) {
            document.documentElement.dataset.initialHeaderScrollY =
                String(savedScrollY);
        }

        document.documentElement.toggleAttribute(
            'data-initial-header-collapsed',
            collapsed,
        );
    } catch {
        // The semantic header remains a complete hero-state fallback.
    }
`;
---

<!doctype html>
<html lang="en" data-time-state="dusk">
    <head>
        <meta charset="UTF-8" />
        <meta name="theme-color" content={SKYLINE_THEME_COLORS.dusk} />
        <script is:inline set:html={skylineStateBootstrapScript} />
        <script is:inline set:html={initialHeaderSurfaceBootstrapScript} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="color-scheme" content="light dark" />
        <title>{title}</title>
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:locale" content="en_CA" />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={socialImageAlt} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={socialImageURL} />
        <meta name="twitter:image:alt" content={socialImageAlt} />

        <script
            is:inline
            type="application/ld+json"
            set:html={profilePageStructuredData}
        />

        <link
            rel="preload"
            href="/fonts/GeneralSans-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/GeneralSans-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    </head>
    <body>
        <a href="#experience" class="skip-link">Skip to experience</a>
        <Header />
        <slot />
    </body>
</html>
