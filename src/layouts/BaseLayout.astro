---
import Header from '../components/Header/Header.astro';
import { getSkylineStateBootstrapScript } from '../scripts/skyline/time-state';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'Albert Yang | Toronto Software Engineer',
    description = 'Albert Yang is a Toronto-based Software Engineer with 6+ years of experience building dependable products and systems used around the world.',
} = Astro.props;

const canonicalURL = 'https://albertyang.ca/';
const skylineStateBootstrapScript = getSkylineStateBootstrapScript();
---

<!doctype html>
<html lang="en" data-time-state="dusk">
    <head>
        <meta charset="UTF-8" />
        <script is:inline set:html={skylineStateBootstrapScript}></script>
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#668aa6" />
        <meta name="color-scheme" content="light dark" />
        <title>{title}</title>
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:locale" content="en_CA" />

        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />

        <link
            rel="preload"
            href="/fonts/GeneralSans-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/GeneralSans-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    </head>
    <body>
        <a href="#experience" class="skip-link">Skip to experience</a>
        <Header />
        <slot />
    </body>
</html>
