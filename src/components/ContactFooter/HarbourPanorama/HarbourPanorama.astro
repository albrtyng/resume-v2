---
import CelestialDisc from '../../CelestialDisc/CelestialDisc.astro';
import DistantTorontoSkyline from '../DistantTorontoSkyline/DistantTorontoSkyline.astro';
import HarbourFerry from '../HarbourFerry/HarbourFerry.astro';
import HarbourReflections from '../HarbourReflections/HarbourReflections.astro';
import IslandBonfire from '../IslandBonfire/IslandBonfire.astro';

import './HarbourPanorama.scss';
---

<svg
    class="harbour-panorama"
    data-harbour-panorama
    viewBox="0 -80 1440 600"
    preserveAspectRatio="xMidYMax slice"
    aria-hidden="true"
    focusable="false"
>
    <defs>
        <linearGradient
            id="harbour-sky-depth-fade"
            x1="0"
            y1="-80"
            x2="0"
            y2="126"
            gradientUnits="userSpaceOnUse"
        >
            <stop
                class="harbour-panorama__sky-depth-stop"
                offset="0"
                stop-opacity="0"></stop>
            <stop class="harbour-panorama__sky-depth-stop" offset="0.25"
            ></stop>
            <stop
                class="harbour-panorama__sky-depth-stop"
                offset="1"
                stop-opacity="0"></stop>
        </linearGradient>
        <pattern
            id="harbour-paint-fleck"
            width="58"
            height="49"
            patternUnits="userSpaceOnUse"
        >
            <circle class="harbour-panorama__fleck" cx="9" cy="12" r="1.7"
            ></circle>
            <circle class="harbour-panorama__fleck" cx="43" cy="34" r="1.1"
            ></circle>
            <path class="harbour-panorama__fleck-line" d="M21 39L31 34"></path>
        </pattern>
        <pattern
            id="harbour-ripple-lines"
            width="92"
            height="36"
            patternUnits="userSpaceOnUse"
        >
            <path
                class="harbour-panorama__ripple"
                d="M8 10H34M52 16H84M18 27H48M64 31H88"></path>
        </pattern>
        <pattern
            id="harbour-sand-stipple"
            width="47"
            height="39"
            patternUnits="userSpaceOnUse"
        >
            <circle class="harbour-panorama__stipple" cx="10" cy="11" r="1.5"
            ></circle>
            <circle class="harbour-panorama__stipple" cx="33" cy="27" r="1.1"
            ></circle>
            <circle class="harbour-panorama__stipple" cx="26" cy="7" r="0.9"
            ></circle>
            <path
                class="harbour-panorama__stipple-line"
                d="M6 31L16 27M30 19L40 16"></path>
        </pattern>
    </defs>

    <g class="harbour-panorama__atmosphere" data-depth="0.06">
