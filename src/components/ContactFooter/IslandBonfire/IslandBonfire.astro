        class="harbour-panorama__reflection-anchor"
        data-footer-reflection-source-anchor="footer-bonfire"
        cx="121"
        cy="194"
        r="1"
    ></circle>
    <g class="island-bonfire__glow" data-bonfire-glow>
        <ellipse
            class="island-bonfire__glow-wash"
            cx="121"
            cy="159"
            rx="105"
            ry="57"></ellipse>
        <ellipse
            class="island-bonfire__glow-core"
            cx="121"
            cy="158"
